# ============================================================
# 1. قراءة SPARC
# ============================================================

def load_sparc(zip_path='Rotmod_LTG.zip', min_points=6):
    galaxies = {}
    with zipfile.ZipFile(zip_path, 'r') as z:
        files = [f for f in z.namelist() if f.endswith('_rotmod.dat')]
        print(f"\n📂 وجدت {len(files)} مجرة في SPARC")
        for fname in files:
            name = fname.replace('_rotmod.dat','').split('/')[-1]
            with z.open(fname) as f:
                lines = f.read().decode('utf-8').strip().split('\n')
            rows = []
            for line in lines:
                if line.startswith('#') or not line.strip():
                    continue
                try:
                    vals = [float(x) for x in line.split()]
                    if len(vals) >= 6:
                        rows.append(vals)
                except:
                    pass
            if len(rows) < min_points:
                continue
            arr  = np.array(rows)
            r    = arr[:,0]
            vobs = arr[:,1]
            verr = np.maximum(arr[:,2], 1.0)  # حد أدنى للخطأ 1 km/s
            vgas = arr[:,3]
            vdsk = arr[:,4]
            vbul = arr[:,5]
            mask = (vobs > 0) & (verr > 0) & (r > 0)
            if mask.sum() < min_points:
                continue
            r    = r[mask];    vobs = vobs[mask]; verr = verr[mask]
            vgas = vgas[mask]; vdsk = vdsk[mask]; vbul = vbul[mask]
            # السرعة البارونية الكاملة مع mass-to-light ratio = 1
            vbar = np.sqrt(vgas**2 + vdsk**2 + vbul**2)
            galaxies[name] = dict(r=r, vobs=vobs, verr=verr,
                                  vbar=vbar, vgas=vgas, vdsk=vdsk, vbul=vbul)
    print(f"✅ تم تحميل {len(galaxies)} مجرة")
    return galaxies

# ============================================================
# 2. نموذج MOND الصحيح — مع mass-to-light ratio كمعامل حر
# ============================================================

A0_ASTRO = 1.2e-10 * 3.086e16 / 1e6  # (km/s)²/kpc = 3703.2

def v_MOND_correct(r, vgas, vdsk, vbul, upsilon):
    """
    MOND القياسي مع mass-to-light ratio
    upsilon: معامل كتلة النجوم (يطبّق على vdsk و vbul)
    """
    vbar2 = vgas**2 + upsilon * (vdsk**2 + vbul**2)
    vbar2 = np.maximum(vbar2, 1e-10)
    
    r_safe = np.maximum(r, 1e-6)
    g_bar  = vbar2 / r_safe  # (km/s)²/kpc
    
    x  = g_bar / A0_ASTRO
    mu = x / np.sqrt(1.0 + x**2)
    mu = np.maximum(mu, 1e-10)
    
    v2 = vbar2 / mu
    return np.sqrt(np.maximum(v2, 1e-10))

def fit_MOND(data):
    """تطبيق MOND مع تحسين Υ"""
    r    = data['r']
    vobs = data['vobs']
    verr = data['verr']
    vgas = data['vgas']
    vdsk = data['vdsk']
    vbul = data['vbul']
    
    def cost(upsilon):
        try:
            vpred = v_MOND_correct(r, vgas, vdsk, vbul, upsilon)
            return np.sum(((vobs - vpred)/verr)**2)
        except:
            return 1e12
    
    res = minimize_scalar(cost, bounds=(0.1, 5.0), method='bounded')
    
    upsilon = res.x
    vpred   = v_MOND_correct(r, vgas, vdsk, vbul, upsilon)
    dof     = max(len(r) - 1, 1)
    chi2    = res.fun / dof
    rms     = np.sqrt(np.mean((vobs - vpred)**2))
    
    return dict(upsilon=upsilon, chi2=chi2, rms=rms, vpred=vpred, success=True)

# ============================================================
# 3. نموذج J الصحيح
# ============================================================

def v_J_correct(r, vgas, vdsk, vbul, upsilon, eta, r_scale, beta):
    """
    نموذج J مع mass-to-light ratio
    """
    vbar2 = vgas**2 + upsilon * (vdsk**2 + vbul**2)
    vbar2 = np.maximum(vbar2, 1e-10)
    
    x     = r / r_scale
    dPhi  = x * np.exp(-0.5 * x**beta)
    maxv  = dPhi.max()
    if maxv > 0:
        dPhi = dPhi / maxv
    
    v2 = vbar2 + eta * dPhi
    return np.sqrt(np.maximum(v2, 1e-10))

def fit_J(data):
    """تطبيق نموذج J مع تحسين كل المعاملات"""
    r    = data['r']
    vobs = data['vobs']
    verr = data['verr']
    vgas = data['vgas']
    vdsk = data['vdsk']
    vbul = data['vbul']
    
    r_max = r.max()
    v_max = vobs.max()
    
    def cost(params):
        upsilon, eta, r_scale, beta = params
        try:
            vpred = v_J_correct(r, vgas, vdsk, vbul, upsilon, eta, r_scale, beta)
            return np.sum(((vobs - vpred)/verr)**2)
        except:
            return 1e12
    
    bounds = [
        (0.1, 5.0),               # Υ — نفس نطاق MOND
        (0.0, v_max**2 * r_max),  # η
        (r_max*0.01, r_max*3),    # r_scale
        (0.3, 4.0)                # β
    ]
    
    res = differential_evolution(
        cost, bounds,
        seed=42, maxiter=1500,
        tol=1e-9, popsize=20,
        mutation=(0.5,1.5), recombination=0.9,
        polish=True
    )
    
    upsilon, eta, r_scale, beta = res.x
    vpred = v_J_correct(r, vgas, vdsk, vbul, upsilon, eta, r_scale, beta)
    dof   = max(len(r) - 4, 1)
    chi2  = res.fun / dof
    rms   = np.sqrt(np.mean((vobs - vpred)**2))
    
    return dict(upsilon=upsilon, eta=eta, r_scale=r_scale, beta=beta,
                chi2=chi2, rms=rms, vpred=vpred, success=True)

# ============================================================
# 4. التحليل الكامل
# ============================================================

def run_analysis(galaxies, max_galaxies=None):
    names = list(galaxies.keys())
    if max_galaxies:
        names = names[:max_galaxies]
    
    print(f"\n🔭 تحليل {len(names)} مجرة...")
    print("-"*62)
    print(f"{'المجرة':<14} {'χ²_J':>7} {'χ²_M':>7} {'Υ_J':>6} {'Υ_M':>6} {'نتيجة':>6}")
    print("-"*62)
    
    results = []
    for i, name in enumerate(names):
        d = galaxies[name]
        try:
            rJ = fit_J(d)
            rM = fit_MOND(d)
            
            winner = "✅J" if rJ['chi2'] < rM['chi2'] else "⚠️M"
            print(f"{name:<14} {rJ['chi2']:>7.2f} {rM['chi2']:>7.2f} "
                  f"{rJ['upsilon']:>6.2f} {rM['upsilon']:>6.2f} {winner:>6}")
            
            results.append(dict(
                name=name,
                chi2_J=rJ['chi2'], rms_J=rJ['rms'], vpred_J=rJ['vpred'],
                chi2_M=rM['chi2'], rms_M=rM['rms'], vpred_M=rM['vpred'],
                upsilon_J=rJ['upsilon'], eta=rJ['eta'],
                r_scale=rJ['r_scale'], beta=rJ['beta'],
                upsilon_M=rM['upsilon'],
                J_wins=rJ['chi2'] < rM['chi2']
            ))
        except Exception as e:
            pass
        
        if (i+1) % 20 == 0:
            print(f"  ... {i+1}/{len(names)} مكتمل")
    
    return results

# ============================================================
# 5. الإحصاءات
# ============================================================

def statistics(results):
    J_wins = sum(1 for r in results if r['J_wins'])
    
    chi2_J = [r['chi2_J'] for r in results]
    chi2_M = [r['chi2_M'] for r in results]
    rms_J  = [r['rms_J']  for r in results]
    etas   = [r['eta']    for r in results]
    rsc    = [r['r_scale']for r in results]
    betas  = [r['beta']   for r in results]
    
    print("\n" + "="*60)
    print("📊 النتائج الإجمالية — Fair Comparison")
    print("="*60)
    print(f"\n  المجرات المحللة:      {len(results)}")
    print(f"  J أفضل من MOND:       {J_wins}/{len(results)} ({100*J_wins/len(results):.1f}%)")
    print(f"\n  χ²_J  (متوسط/وسيط) = {np.mean(chi2_J):.2f} / {np.median(chi2_J):.2f}")
    print(f"  χ²_M  (متوسط/وسيط) = {np.mean(chi2_M):.2f} / {np.median(chi2_M):.2f}")
    print(f"  RMS_J (متوسط)       = {np.mean(rms_J):.1f} km/s")
    print(f"\n  ─── معاملات J ───")
    print(f"  η      (وسيط) = {np.median(etas):.0f} (km/s)² kpc")
    print(f"  r_scale(وسيط) = {np.median(rsc):.1f} kpc")
    print(f"  β      (وسيط) = {np.median(betas):.2f}")
    
    improvement = np.median(chi2_M) / np.median(chi2_J)
    print(f"\n  تحسن J على MOND (وسيط): {improvement:.1f}x")
    
    return dict(
        n=len(results), J_wins=J_wins,
        chi2_J_mean=np.mean(chi2_J), chi2_J_med=np.median(chi2_J),
        chi2_M_mean=np.mean(chi2_M), chi2_M_med=np.median(chi2_M),
        rms_J=np.mean(rms_J),
        eta_med=np.median(etas), rscale_med=np.median(rsc),
        beta_med=np.median(betas), improvement=improvement
    )

